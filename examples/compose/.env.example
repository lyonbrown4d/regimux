# Compose-only values.
REGIMUX_IMAGE=ghcr.io/lyonbrown4d/regimux:latest
REGIMUX_HTTP_PORT=8080
GRAFANA_HTTP_PORT=3000
GRAFANA_ADMIN_PASSWORD=regimux

# Runtime config overrides consumed by configx inside the regimux container.
# Use double underscores to address nested config paths.
REGIMUX_SERVER__PUBLIC_URL=http://localhost:8080
REGIMUX_LOG__LEVEL=info
REGIMUX_CACHE__PREFIX=regimux
REGIMUX_CACHE__DEFAULT_TTL=10m
REGIMUX_UPSTREAMS__HUB__REGISTRY=https://registry-1.docker.io
REGIMUX_UPSTREAMS__HUB__DEFAULT_NAMESPACE=library
# REGIMUX_WORKER__IO_CONCURRENCY=17
REGIMUX_WORKER__LEASE_CONCURRENCY=64

# Optional local auth example. Uncomment and change these values to require
# docker login for pulls through RegiMux.
# REGIMUX_AUTH__ENABLED=true
# REGIMUX_AUTH__TOKEN_SECRET=change-me
# REGIMUX_AUTH__USERS__ALICE__PASSWORD=secret
# REGIMUX_AUTH__USERS__ALICE__REPOSITORIES=hub/*

# Optional S3-compatible object store example. These can point at MinIO,
# AWS S3, R2, or another S3-compatible service.
# REGIMUX_STORE__OBJECT__DRIVER=s3
# REGIMUX_STORE__OBJECT__S3__BUCKET=regimux-objects
# REGIMUX_STORE__OBJECT__S3__PREFIX=cache
# REGIMUX_STORE__OBJECT__S3__REGION=us-east-1
# REGIMUX_STORE__OBJECT__S3__ENDPOINT=http://minio:9000
# REGIMUX_STORE__OBJECT__S3__ACCESS_KEY_ID=regimux
# REGIMUX_STORE__OBJECT__S3__SECRET_ACCESS_KEY=change-me
# REGIMUX_STORE__OBJECT__S3__FORCE_PATH_STYLE=true
# REGIMUX_STORE__OBJECT__S3__PART_SIZE=16777216
# REGIMUX_STORE__OBJECT__S3__UPLOAD_CONCURRENCY=4
