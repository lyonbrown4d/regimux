# Compose-only values.
REGIMUX_IMAGE=ghcr.io/lyonbrown4d/regimux:latest
REGIMUX_HTTP_PORT=5000

# Runtime config overrides consumed by configx inside the regimux container.
# Use double underscores to address nested config paths.
REGIMUX_SERVER__PUBLIC_URL=http://localhost:5000
REGIMUX_LOG__LEVEL=info
REGIMUX_CACHE__PREFIX=regimux
REGIMUX_CACHE__DEFAULT_TTL=10m
REGIMUX_UPSTREAMS__HUB__REGISTRY=https://registry-1.docker.io
REGIMUX_UPSTREAMS__HUB__DEFAULT_NAMESPACE=library
REGIMUX_WORKER__PROBE_CONCURRENCY=16
REGIMUX_WORKER__PREFETCH_CONCURRENCY=8

# Optional local auth example. Uncomment and change these values to require
# docker login for pulls through RegiMux.
# REGIMUX_AUTH__ENABLED=true
# REGIMUX_AUTH__TOKEN_SECRET=change-me
# REGIMUX_AUTH__USERS__ALICE__PASSWORD=secret
# REGIMUX_AUTH__USERS__ALICE__REPOSITORIES=hub/*
